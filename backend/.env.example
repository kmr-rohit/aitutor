APP_ENV=dev
API_PREFIX=/api
LLM_PROVIDER=mock
STT_PROVIDER=mock
TTS_PROVIDER=mock
SARVAM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=codemix
SARVAM_STT_LANGUAGE_CODE=unknown
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=hi-IN
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=1.0

REQUEST_TIMEOUT_SECONDS=30
ENABLE_HINGLISH_REFINER=true
HINGLISH_REFINER_MODEL=
ENABLE_DEEP_REPORT=true
DEEP_REPORT_MODEL=
